{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm ci",
  "framework": "nextjs",
  "nodejs": "20.x",
  "env": {
    "GEMINI_API_KEY": {
      "description": "Google Gemini API Key for carbon insights",
      "required": true
    }
  },
  "regions": ["iad1"],
  "functions": {
    "app/api/**/*.ts": {
      "memory": 3008,
      "maxDuration": 60
    }
  }
}
